{"schema":{"type":"object","description":"Configured automation action","properties":{"id":{"type":"string","example":"01HX9QRPBZW4EZG3BTYV7K0M5A"},"name":{"type":"string","example":"notify-on-complete"},"profileId":{"type":"string","nullable":true,"example":"acme-corp"},"actionType":{"type":"string","description":"Type of automation action to execute","enum":["WEBHOOK","KAFKA_PUBLISH","EMAIL","SLACK","ARCHIVE_FILE","CUSTOM_SCRIPT"],"example":"WEBHOOK","title":"ActionType"},"trigger":{"type":"string","description":"Pipeline event that fires the action","enum":["ON_COMPLETION","ON_FAILURE","ON_PARTIAL_FAILURE","ON_THRESHOLD_BREACH","ON_SCHEDULE","MANUAL"],"example":"ON_COMPLETION","title":"ActionTrigger"},"enabled":{"type":"boolean","example":true},"lastTriggeredAt":{"type":"string","format":"date-time","nullable":true,"example":"2024-03-15T10:30:00Z"},"createdAt":{"type":"string","format":"date-time","example":"2024-03-15T08:00:00Z"},"updatedAt":{"type":"string","format":"date-time","example":"2024-03-15T09:30:00Z"}},"title":"ActionResponse"},"schemaType":"response"}