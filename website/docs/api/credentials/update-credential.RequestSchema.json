{"title":"Body","body":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["name","credentialType"],"description":"Payload to store a new credential or rotate an existing one","properties":{"name":{"type":"string","example":"acme-sftp-key"},"credentialType":{"type":"string","description":"Type of credential secret","enum":["SSH_KEY","PASSWORD","API_TOKEN","AWS_ACCESS_KEY","AZURE_SAS","GCP_SERVICE_ACCOUNT","OAUTH2_CLIENT"],"example":"SSH_KEY","title":"CredentialType"},"username":{"type":"string","description":"Username (SSH_KEY, PASSWORD)","example":"sftp-user"},"password":{"type":"string","format":"password","description":"Password (PASSWORD type)","example":"s3cr3t!"},"privateKey":{"type":"string","description":"PEM-encoded private key (SSH_KEY type)","example":"-----BEGIN RSA PRIVATE KEY-----\n..."},"token":{"type":"string","format":"password","description":"API token or bearer token (API_TOKEN type)"},"accessKeyId":{"type":"string","description":"AWS access key ID (AWS_ACCESS_KEY type)","example":"AKIAIOSFODNN7EXAMPLE"},"secretAccessKey":{"type":"string","format":"password","description":"AWS secret access key (AWS_ACCESS_KEY type)"}},"title":"CreateCredentialRequest"}}}}}