{"schema":{"type":"object","required":["id","frequency"],"properties":{"id":{"type":"string","example":"acme-payments-window"},"frequency":{"type":"object","required":["startCronExpression","endCronExpression"],"properties":{"startCronExpression":{"type":"string","description":"6-field Spring cron expression that OPENS the window","example":"0 0/30 * * * ?"},"endCronExpression":{"type":"string","description":"6-field Spring cron expression that CLOSES the window","example":"0 29/30 * * * ?"},"recurringInterval":{"type":"string","description":"ISO-8601 duration for RECURRING_WHILE_OPEN actions","example":"PT5M"}},"title":"WindowFrequency"},"autoCreateDefaultWindow":{"type":"boolean","default":true,"description":"Create a window instance even if no events are collected"},"maxDurationMinutes":{"type":"integer","description":"Safety cap — force-close if window stays open beyond this duration"},"timezone":{"type":"string","default":"UTC","example":"America/New_York"},"deduplication":{"type":"object","properties":{"enabled":{"type":"boolean","default":true},"strategy":{"type":"string","enum":["PAYLOAD_HASH","FIELD_BASED","NONE"],"default":"PAYLOAD_HASH"},"fields":{"type":"array","items":{"type":"string"},"description":"Field names for FIELD_BASED strategy"}}}},"title":"WindowConfigSchema"},"schemaType":"response"}