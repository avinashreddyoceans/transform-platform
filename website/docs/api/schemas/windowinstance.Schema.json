{"schema":{"type":"object","properties":{"instanceId":{"type":"string","format":"uuid"},"windowConfigId":{"type":"string"},"profileId":{"type":"string"},"state":{"type":"string","enum":["PENDING","OPENING","OPEN","CLOSING","CLOSED","ERROR"],"title":"WindowState"},"openedAt":{"type":"string","format":"date-time"},"closedAt":{"type":"string","format":"date-time"},"eventCount":{"type":"integer","format":"int64"},"lastEventAt":{"type":"string","format":"date-time"},"actionResults":{"type":"array","items":{"type":"object","properties":{"actionId":{"type":"string"},"condition":{"type":"string","enum":["ON_OPEN","ON_CLOSING","RECURRING_WHILE_OPEN","ON_EMPTY_CLOSE","ON_THRESHOLD_REACHED","ON_ERROR","ON_MANUAL_TRIGGER","ON_DUPLICATE_DETECTED"],"description":"- `ON_OPEN` — fires when the window opens\n- `ON_CLOSING` — fires when the window closes\n- `RECURRING_WHILE_OPEN` — fires on `recurringInterval` while window is open\n- `ON_EMPTY_CLOSE` — fires at close if zero events were collected\n- `ON_THRESHOLD_REACHED` — fires when event count crosses a configured threshold\n- `ON_ERROR` — fires when any action in the chain fails\n- `ON_MANUAL_TRIGGER` — fires only via explicit API call\n- `ON_DUPLICATE_DETECTED` — fires when a duplicate event is rejected\n","title":"ActionCondition"},"type":{"type":"string","enum":["FILE_TO_EVENTS","EVENTS_TO_FILE","NOTIFY","VALIDATE_COMPLETENESS","TRANSFORM_AND_ROUTE","ARCHIVE","INVOKE_EXTERNAL"],"title":"ActionType"},"status":{"type":"string","enum":["PENDING","RUNNING","SUCCESS","FAILED","SKIPPED","TIMEOUT"],"title":"ActionStatus"},"startedAt":{"type":"string","format":"date-time"},"completedAt":{"type":"string","format":"date-time"},"recordsProcessed":{"type":"integer","format":"int64"},"error":{"type":"string"},"retryCount":{"type":"integer"}},"title":"ActionResult"}},"error":{"type":"string"}},"title":"WindowInstance"},"schemaType":"response"}