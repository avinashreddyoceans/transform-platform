{"schema":{"type":"object","required":["format","fieldMappings"],"description":"Optional outbound pipeline configuration. When present, the spec supports\nthe Events → File pipeline in addition to (or instead of) File → Events.\n","properties":{"format":{"type":"string","enum":["CSV","FIXED_WIDTH","XML","JSON","NACHA","ISO20022","SWIFT_MT","EDI"],"description":"File format supported by the platform","title":"FileFormat"},"fieldMappings":{"type":"array","items":{"type":"object","required":["sourceField","targetField"],"properties":{"sourceField":{"type":"string","description":"Field name in the incoming event","example":"transactionId"},"targetField":{"type":"string","description":"Field name in the generated file","example":"TXN_ID"},"transform":{"type":"string","enum":["NONE","UPPERCASE","LOWERCASE","DATE_REFORMAT","AMOUNT_CENTS_TO_DECIMAL","AMOUNT_DECIMAL_TO_CENTS"],"default":"NONE"},"defaultValue":{"type":"string"}},"title":"FieldMapping"}},"fieldOrder":{"type":"array","items":{"type":"string"},"description":"Order of fields in the output file"},"correctionRules":{"type":"array","items":{"type":"object","required":["type","applyOrder"],"properties":{"type":{"type":"string","enum":["TRIM","UPPERCASE","LOWERCASE","PAD_LEFT","PAD_RIGHT","REPLACE","STRIP_NON_NUMERIC","FORMAT_DATE"]},"fields":{"type":"array","items":{"type":"string"},"description":"Field names to apply the rule to. Use `[\"*\"]` for all fields.","example":["currency"]},"applyOrder":{"type":"integer","description":"Execution order (ascending). Lower numbers run first.","example":1},"params":{"type":"object","description":"Type-specific parameters (e.g. `padChar`, `width`, `fromPattern`, `toPattern`)","additionalProperties":true}},"title":"CorrectionRule"}},"validationRules":{"type":"array","items":{"type":"object","required":["type"],"properties":{"type":{"type":"string","enum":["NOT_EMPTY","CROSS_FIELD_REQUIRED","CONDITIONAL_REQUIRED","UNIQUE_KEY","REFERENTIAL_INTEGRITY"]},"fields":{"type":"array","it