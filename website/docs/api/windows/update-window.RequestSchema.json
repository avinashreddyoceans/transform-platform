{"title":"Body","body":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["name","windowType"],"description":"Payload to create or update a processing window","properties":{"name":{"type":"string","example":"payments-5min"},"profileId":{"type":"string","description":"Associate with a profile (optional)","example":"acme-corp"},"windowType":{"type":"string","description":"Processing window strategy","enum":["TUMBLING","SLIDING","SESSION","TIME_BASED","COUNT_BASED","EVENT_TRIGGERED"],"example":"TUMBLING","title":"WindowType"},"durationMs":{"type":"integer","format":"int64","description":"Window duration in milliseconds (time-based windows)","example":300000},"maxRecords":{"type":"integer","format":"int64","description":"Maximum records before flushing (count-based windows)","example":10000},"cronExpression":{"type":"string","description":"Flush schedule for TIME_BASED windows","example":"0 0 * * *"},"allowLateArrivals":{"type":"boolean","default":false,"description":"Accept records arriving after the window closes"},"latencyToleranceMs":{"type":"integer","format":"int64","description":"Grace period for late records (ms)","example":5000}},"title":"CreateWindowRequest"}}}}}