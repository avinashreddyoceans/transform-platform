# ─── IntelliJ IDEA ────────────────────────────────────────────────────────────
# Ignore all .idea/ contents except run configurations.
# IMPORTANT: use .idea/* (not .idea/) so that git descends into .idea/
# and honours the !runConfigurations/ negation below.
.idea/*
!.idea/runConfigurations/
*.iml
*.iws
*.ipr
out/

# ─── Gradle ───────────────────────────────────────────────────────────────────
.gradle/
build/
*/build/
**/build/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties

# ─── Spring Boot ──────────────────────────────────────────────────────────────
HELP.md
*.jar
!gradle/wrapper/gradle-wrapper.jar

# ─── Secrets — NEVER commit these ────────────────────────────────────────────
application-local.yml
application-local.yaml
application-secrets.yml
*.env
.env
.env.*
secrets/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
**/logs/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── Docker volumes ───────────────────────────────────────────────────────────
postgres_data/

# ─── Temp / test output ───────────────────────────────────────────────────────
tmp/
temp/
*.tmp
test-output/

# ─── Docusaurus ───────────────────────────────────────────────────────────────
website/node_modules/
website/.docusaurus/
website/build/
# Built output — deployed via GitHub Actions Pages, never committed to main
/docs/

# HTTP Client — private env contains real tokens, never commit
http/http-client.private.env.json
