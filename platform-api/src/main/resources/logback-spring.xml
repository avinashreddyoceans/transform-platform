<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Transform Platform — Structured Logging
        ════════════════════════════════════════════════════════════════════════
        MDC identifiers present on every HTTP request log line:
          traceId       — OTel trace ID   (written by TracingMdcFilter)
          spanId        — OTel span ID    (written by TracingMdcFilter)
          correlationId — request ID      (written by CorrelationIdFilter)
          service, env  — static fields from application.yml
          profileId, windowId, specId — set by domain code via MDC.put(...)

        For non-HTTP threads (Kafka, schedulers) that have an active OTel span,
        OtelTracingAppender enriches the log event's MDC snapshot at append time.

        Profiles:
          dev-text   → human-readable text console + rolling file
          (default)  → JSON console + rolling file  (used in all other envs)
    ════════════════════════════════════════════════════════════════════════ -->

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="transform-platform"/>
    <springProperty scope="context" name="appEnv"  source="spring.profiles.active"  defaultValue="local"/>

    <!-- ── Destination appenders ──────────────────────────────────────────────── -->

    <appender name="FILE_RAW" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.dir}/logs/transform-platform.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${user.dir}/logs/transform-platform.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
            <customFields>{"service":"${appName}","env":"${appEnv}"}</customFields>
            <!-- MDC keys — traceId/spanId written by TracingMdcFilter; correlationId by CorrelationIdFilter -->
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>profileId</includeMdcKeyName>
            <includeMdcKeyName>windowId</includeMdcKeyName>
            <includeMdcKeyName>specId</includeMdcKeyName>
            <includeMdcKeyName>clientId</includeMdcKeyName>
            <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerCause>20</maxDepthPerCause>
                <maxLength>8192</maxLength>
                <rootCauseFirst>true</rootCauseFirst>
            </throwableConverter>
        </encoder>
    </appender>

    <appender name="JSON_CONSOLE_RAW" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
            <customFields>{"service":"${appName}","env":"${appEnv}"}</customFields>
            <!-- MDC keys — traceId/spanId written by TracingMdcFilter; correlationId by CorrelationIdFilter -->
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>profileId</includeMdcKeyName>
            <includeMdcKeyName>windowId</includeMdcKeyName>
            <includeMdcKeyName>specId</includeMdcKeyName>
            <includeMdcKeyName>clientId</includeMdcKeyName>
            <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerCause>20</maxDepthPerCause>
                <maxLength>8192</maxLength>
                <rootCauseFirst>true</rootCauseFirst>
            </throwableConverter>
        </encoder>
    </appender>

    <appender name="TEXT_CONSOLE_RAW" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- traceId/spanId from TracingMdcFilter; correlationId from CorrelationIdFilter -->
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%X{traceId:-no-trace}] [%X{correlationId:-no-corr}] %cyan(%logger{36}) - %msg%n%ex</pattern>
        </encoder>
    </appender>

    <!-- ── OtelTracingAppender — non-HTTP thread coverage ───────────────────────
         Used for Kafka consumers, scheduled tasks, and other non-Servlet threads
         that have an active OTel span but are not covered by TracingMdcFilter.
         For HTTP request threads, TracingMdcFilter writes traceId/spanId to MDC
         before any business code runs, so the MDC snapshot already has them.
    ──────────────────────────────────────────────────────────────────────────── -->

    <appender name="ASYNC_OTEL" class="com.transformplatform.api.logging.OtelTracingAppender">
        <appender-ref ref="FILE_RAW"/>
    </appender>

    <!-- ── Root loggers ──────────────────────────────────────────────────────── -->

    <springProfile name="dev-text">
        <root level="INFO">
            <appender-ref ref="TEXT_CONSOLE_RAW"/>
            <appender-ref ref="FILE_RAW"/>
        </root>
    </springProfile>

    <springProfile name="!dev-text">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE_RAW"/>
            <appender-ref ref="FILE_RAW"/>
        </root>
    </springProfile>

    <!-- ── Package-level log levels ─────────────────────────────────────────── -->
    <logger name="com.transformplatform"     level="DEBUG"/>
    <logger name="org.springframework.kafka" level="INFO"/>
    <logger name="org.hibernate.SQL"         level="INFO"/>
    <!-- Suppress noisy OTel startup logs — raise to DEBUG when diagnosing OTel issues -->
    <logger name="io.opentelemetry"          level="WARN"/>
    <logger name="io.micrometer.tracing"     level="WARN"/>

</configuration>
