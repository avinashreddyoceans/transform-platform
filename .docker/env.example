# ─────────────────────────────────────────────────────────────────────────────
# Transform Platform — Environment Variables Reference
# Copy this file to .env and fill in real values before running locally.
# NEVER commit a filled-in .env file — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_USER=transform_user
DB_PASS=transform_pass
# Full JDBC URL — override if Postgres is not on localhost
# DB_URL=jdbc:postgresql://localhost:5432/transform_platform

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Application Server ────────────────────────────────────────────────────────
PORT=8080

# ── Security ──────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Replace before deploying to any environment.
JWT_SECRET=local-dev-secret-replace-this-before-any-real-deployment

# ── File Processing ───────────────────────────────────────────────────────────
TEMP_DIR=/tmp/transform-platform
# Set to true in staging/prod; false is fine for local dev (skips AES setup)
ENCRYPTION_ENABLED=false

# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
