    {
      "name": "02 · Spec — CSV",
      "description": "CRUD for CSV file specs. The Create request auto-saves the spec ID into {{csvSpecId}} via a test script.",
      "item": [
        {
          "name": "Create CSV spec",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has id', () => pm.expect(pm.response.json().id).to.exist);",
                  "const id = pm.response.json().id;",
                  "pm.collectionVariables.set('csvSpecId', id);",
                  "pm.environment.set('csvSpecId', id);",
                  "console.log('CSV spec created:', id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"bank-transaction-csv-v1\",\n  \"description\": \"Daily bank transaction export — pipe-delimited with header row\",\n  \"version\": \"1.0\",\n  \"format\": \"CSV\",\n  \"encoding\": \"UTF-8\",\n  \"hasHeader\": true,\n  \"delimiter\": \"|\",\n  \"skipLinesCount\": 0,\n  \"fields\": [\n    {\n      \"name\": \"transactionId\",\n      \"displayName\": \"Transaction ID\",\n      \"type\": \"STRING\",\n      \"columnName\": \"TRANSACTION_ID\",\n      \"required\": true,\n      \"maxLength\": 36\n    },\n    {\n      \"name\": \"accountNumber\",\n      \"displayName\": \"Account Number\",\n      \"type\": \"ACCOUNT_NUMBER\",\n      \"columnName\": \"ACCOUNT_NO\",\n      \"required\": true,\n      \"sensitive\": true\n    },\n    {\n      \"name\": \"routingNumber\",\n      \"displayName\": \"Routing Number\",\n      \"type\": \"ROUTING_NUMBER\",\n      \"columnName\": \"ROUTING_NO\",\n      \"required\": true,\n      \"sensitive\": true\n    },\n    {\n      \"name\": \"amount\",\n      \"displayName\": \"Amount\",\n      \"type\": \"AMOUNT\",\n      \"columnName\": \"AMOUNT\",\n      \"required\": true,\n      \"scale\": 2\n    },\n    {\n      \"name\": \"transactionDate\",\n      \"displayName\": \"Transaction Date\",\n      \"type\": \"DATE\",\n      \"columnName\": \"TXN_DATE\",\n      \"required\": true,\n      \"format\": \"yyyy-MM-dd\"\n    },\n    {\n      \"name\": \"transactionType\",\n      \"displayName\": \"Transaction Type\",\n      \"type\": \"ENUM\",\n      \"columnName\": \"TXN_TYPE\",\n      \"required\": true,\n      \"allowedValues\": [\"CREDIT\", \"DEBIT\", \"REVERSAL\", \"FEE\"]\n    },\n    {\n      \"name\": \"description\",\n      \"displayName\": \"Description\",\n      \"type\": \"STRING\",\n      \"columnName\": \"DESCRIPTION\",\n      \"required\": false,\n      \"nullable\": true,\n      \"maxLength\": 255\n    },\n    {\n      \"name\": \"status\",\n      \"displayName\": \"Status\",\n      \"type\": \"ENUM\",\n      \"columnName\": \"STATUS\",\n      \"required\": true,\n      \"allowedValues\": [\"POSTED\", \"PENDING\", \"REJECTED\"],\n      \"defaultValue\": \"POSTED\"\n    }\n  ],\n  \"validationRules\": [\n    {\n      \"ruleId\": \"amount-positive\",\n      \"field\": \"amount\",\n      \"ruleType\": \"MIN_VALUE\",\n      \"value\": \"0.01\",\n      \"message\": \"Transaction amount must be positive\",\n      \"severity\": \"ERROR\"\n    },\n    {\n      \"ruleId\": \"routing-length\",\n      \"field\": \"routingNumber\",\n      \"ruleType\": \"EXACT_LENGTH\",\n      \"value\": \"9\",\n      \"message\": \"Routing number must be exactly 9 digits\",\n      \"severity\": \"ERROR\"\n    },\n    {\n      \"ruleId\": \"account-not-empty\",\n      \"field\": \"accountNumber\",\n      \"ruleType\": \"NOT_EMPTY\",\n      \"message\": \"Account number is required\",\n      \"severity\": \"FATAL\"\n    }\n  ],\n  \"correctionRules\": [\n    {\n      \"ruleId\": \"trim-description\",\n      \"field\": \"description\",\n      \"correctionType\": \"TRIM\",\n      \"applyOrder\": 1\n    },\n    {\n      \"ruleId\": \"uppercase-type\",\n      \"field\": \"transactionType\",\n      \"correctionType\": \"UPPERCASE\",\n      \"applyOrder\": 2\n    },\n    {\n      \"ruleId\": \"strip-amount-symbols\",\n      \"field\": \"amount\",\n      \"correctionType\": \"NUMBER_FORMAT_COERCE\",\n      \"applyOrder\": 3\n    },\n    {\n      \"ruleId\": \"coerce-date\",\n      \"field\": \"transactionDate\",\n      \"correctionType\": \"DATE_FORMAT_COERCE\",\n      \"applyOrder\": 4\n    }\n  ],\n  \"metadata\": {\n    \"source\": \"core-banking-system\",\n    \"team\": \"payments\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/specs", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs"] }
          }
        },
        {
          "name": "List all specs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/specs?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "specs"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "List CSV specs (filtered)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/specs?format=CSV&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "specs"],
              "query": [
                { "key": "format", "value": "CSV" },
                { "key": "page",   "value": "0" },
                { "key": "size",   "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get CSV spec by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Format is CSV', () => pm.expect(pm.response.json().format).to.equal('CSV'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/specs/{{csvSpecId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs", "{{csvSpecId}}"] }
          }
        },
        {
          "name": "Update CSV spec (bump to v1.1)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"bank-transaction-csv-v1\",\n  \"description\": \"Daily bank transaction export — pipe-delimited with header row\",\n  \"version\": \"1.1\",\n  \"format\": \"CSV\",\n  \"encoding\": \"UTF-8\",\n  \"hasHeader\": true,\n  \"delimiter\": \"|\",\n  \"skipLinesCount\": 0,\n  \"fields\": [\n    { \"name\": \"transactionId\",   \"type\": \"STRING\",         \"columnName\": \"TRANSACTION_ID\", \"required\": true,  \"maxLength\": 36 },\n    { \"name\": \"accountNumber\",   \"type\": \"ACCOUNT_NUMBER\", \"columnName\": \"ACCOUNT_NO\",     \"required\": true,  \"sensitive\": true },\n    { \"name\": \"amount\",          \"type\": \"AMOUNT\",         \"columnName\": \"AMOUNT\",         \"required\": true,  \"scale\": 2 },\n    { \"name\": \"transactionDate\", \"type\": \"DATE\",           \"columnName\": \"TXN_DATE\",       \"required\": true,  \"format\": \"yyyy-MM-dd\" },\n    { \"name\": \"transactionType\", \"type\": \"ENUM\",           \"columnName\": \"TXN_TYPE\",       \"required\": true,  \"allowedValues\": [\"CREDIT\", \"DEBIT\", \"REVERSAL\", \"FEE\"] },\n    { \"name\": \"referenceId\",     \"type\": \"STRING\",         \"columnName\": \"REF_ID\",         \"required\": false, \"nullable\": true, \"maxLength\": 50, \"description\": \"Added in v1.1\" }\n  ],\n  \"validationRules\": [],\n  \"correctionRules\": [],\n  \"metadata\": { \"source\": \"core-banking-system\", \"team\": \"payments\" }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/specs/{{csvSpecId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs", "{{csvSpecId}}"] }
          }
        },
        {
          "name": "Validate CSV spec",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/specs/{{csvSpecId}}/validate", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs", "{{csvSpecId}}", "validate"] }
          }
        },
        {
          "name": "Delete CSV spec",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/specs/{{csvSpecId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs", "{{csvSpecId}}"] }
          }
        },
        {
          "name": "ERROR — missing name (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status is 400', () => pm.response.to.have.status(400));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"description\": \"Missing name\", \"format\": \"CSV\", \"fields\": [] }",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/specs", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs"] }
          }
        },
        {
          "name": "ERROR — spec not found (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status is 404', () => pm.response.to.have.status(404));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/specs/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs", "00000000-0000-0000-0000-000000000000"] }
          }
        }
      ]
    },

    {
      "name": "03 · Spec — Fixed-Width (NACHA)",
      "description": "CRUD for NACHA ACH Entry Detail fixed-width specs. Fields use startPosition + length.",
      "item": [
        {
          "name": "Create fixed-width spec",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Format is FIXED_WIDTH', () => pm.expect(pm.response.json().format).to.equal('FIXED_WIDTH'));",
                  "const id = pm.response.json().id;",
                  "pm.collectionVariables.set('fixedWidthSpecId', id);",
                  "pm.environment.set('fixedWidthSpecId', id);",
                  "console.log('Fixed-width spec created:', id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"nacha-ach-entry-detail-v1\",\n  \"description\": \"NACHA ACH Entry Detail record — 94-character fixed-width\",\n  \"version\": \"1.0\",\n  \"format\": \"FIXED_WIDTH\",\n  \"encoding\": \"UTF-8\",\n  \"hasHeader\": false,\n  \"skipLinesCount\": 1,\n  \"fields\": [\n    { \"name\": \"recordTypeCode\",  \"type\": \"STRING\",         \"startPosition\": 1,  \"length\": 1,  \"required\": true, \"allowedValues\": [\"6\"] },\n    { \"name\": \"transactionCode\", \"type\": \"STRING\",         \"startPosition\": 2,  \"length\": 3,  \"required\": true, \"allowedValues\": [\"022\",\"023\",\"027\",\"028\",\"032\",\"037\",\"038\"] },\n    { \"name\": \"routingNumber\",   \"type\": \"ROUTING_NUMBER\", \"startPosition\": 5,  \"length\": 9,  \"required\": true, \"sensitive\": true, \"validationRegex\": \"^[0-9]{9}$\" },\n    { \"name\": \"accountNumber\",   \"type\": \"ACCOUNT_NUMBER\", \"startPosition\": 15, \"length\": 17, \"required\": true, \"sensitive\": true },\n    { \"name\": \"amount\",          \"type\": \"AMOUNT\",         \"startPosition\": 32, \"length\": 10, \"required\": true, \"scale\": 2, \"description\": \"In cents — 0000150000 = $1,500.00\" },\n    { \"name\": \"individualId\",    \"type\": \"STRING\",         \"startPosition\": 42, \"length\": 15, \"required\": false, \"nullable\": true },\n    { \"name\": \"individualName\",  \"type\": \"STRING\",         \"startPosition\": 57, \"length\": 22, \"required\": true, \"maxLength\": 22 },\n    { \"name\": \"traceNumber\",     \"type\": \"STRING\",         \"startPosition\": 88, \"length\": 7,  \"required\": true, \"validationRegex\": \"^[0-9]{7}$\" }\n  ],\n  \"validationRules\": [\n    { \"ruleId\": \"amount-non-zero\",       \"field\": \"amount\",         \"ruleType\": \"MIN_VALUE\",  \"value\": \"0.01\",        \"message\": \"ACH amount must be greater than zero\",    \"severity\": \"ERROR\" },\n    { \"ruleId\": \"individual-name-req\",   \"field\": \"individualName\", \"ruleType\": \"NOT_EMPTY\",  \"message\": \"Receiver name is required\",                \"severity\": \"FATAL\" },\n    { \"ruleId\": \"routing-regex\",         \"field\": \"routingNumber\",  \"ruleType\": \"REGEX\",      \"value\": \"^[0-9]{9}$\",  \"message\": \"Routing must be exactly 9 digits\",       \"severity\": \"ERROR\" }\n  ],\n  \"correctionRules\": [\n    { \"ruleId\": \"trim-account\",       \"field\": \"accountNumber\",  \"correctionType\": \"TRIM\", \"applyOrder\": 1 },\n    { \"ruleId\": \"trim-individual-id\", \"field\": \"individualId\",   \"correctionType\": \"TRIM\", \"applyOrder\": 2 },\n    { \"ruleId\": \"trim-name\",          \"field\": \"individualName\", \"correctionType\": \"TRIM\", \"applyOrder\": 3 }\n  ],\n  \"metadata\": { \"standard\": \"NACHA-2024\", \"recordType\": \"6\", \"team\": \"ach-processing\" }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/specs", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs"] }
          }
        },
        {
          "name": "List fixed-width specs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/specs?format=FIXED_WIDTH&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "specs"],
              "query": [
                { "key": "format", "value": "FIXED_WIDTH" },
                { "key": "page",   "value": "0" },
                { "key": "size",   "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get fixed-width spec by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/specs/{{fixedWidthSpecId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs", "{{fixedWidthSpecId}}"] }
          }
        },
        {
          "name": "Validate fixed-width spec",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/specs/{{fixedWidthSpecId}}/validate", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs", "{{fixedWidthSpecId}}", "validate"] }
          }
        },
        {
          "name": "Delete fixed-width spec",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/specs/{{fixedWidthSpecId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs", "{{fixedWidthSpecId}}"] }
          }
        }
      ]
    },

    {
      "name": "04 · Spec — XML (ISO 20022)",
      "description": "CRUD for XML specs. Fields are addressed by XPath (path property). XML attributes use xmlAttribute.",
      "item": [
        {
          "name": "Create XML spec",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Format is XML', () => pm.expect(pm.response.json().format).to.equal('XML'));",
                  "const id = pm.response.json().id;",
                  "pm.collectionVariables.set('xmlSpecId', id);",
                  "pm.environment.set('xmlSpecId', id);",
                  "console.log('XML spec created:', id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iso20022-pain001-v1\",\n  \"description\": \"ISO 20022 Customer Credit Transfer Initiation (pain.001) — simplified\",\n  \"version\": \"1.0\",\n  \"format\": \"XML\",\n  \"encoding\": \"UTF-8\",\n  \"hasHeader\": false,\n  \"fields\": [\n    { \"name\": \"messageId\",           \"type\": \"STRING\",   \"path\": \"/Document/CstmrCdtTrfInitn/GrpHdr/MsgId\",                                               \"required\": true, \"maxLength\": 35 },\n    { \"name\": \"creationDateTime\",    \"type\": \"DATETIME\", \"path\": \"/Document/CstmrCdtTrfInitn/GrpHdr/CreDtTm\",                                              \"required\": true, \"format\": \"yyyy-MM-dd'T'HH:mm:ss\" },\n    { \"name\": \"numberOfTransactions\",\"type\": \"INTEGER\",  \"path\": \"/Document/CstmrCdtTrfInitn/GrpHdr/NbOfTxs\",                                              \"required\": true },\n    { \"name\": \"controlSum\",          \"type\": \"AMOUNT\",   \"path\": \"/Document/CstmrCdtTrfInitn/GrpHdr/CtrlSum\",                                              \"required\": true, \"scale\": 2 },\n    { \"name\": \"initiatingPartyName\", \"type\": \"STRING\",   \"path\": \"/Document/CstmrCdtTrfInitn/GrpHdr/InitgPty/Nm\",                                          \"required\": true, \"maxLength\": 140 },\n    { \"name\": \"paymentMethod\",       \"type\": \"ENUM\",     \"path\": \"/Document/CstmrCdtTrfInitn/PmtInf/PmtMtd\",                                              \"required\": true, \"allowedValues\": [\"TRF\",\"CHK\",\"DD\"] },\n    { \"name\": \"requestedExecutionDate\",\"type\": \"DATE\",  \"path\": \"/Document/CstmrCdtTrfInitn/PmtInf/ReqdExctnDt\",                                          \"required\": true, \"format\": \"yyyy-MM-dd\" },\n    { \"name\": \"debtorName\",          \"type\": \"STRING\",   \"path\": \"/Document/CstmrCdtTrfInitn/PmtInf/Dbtr/Nm\",                                              \"required\": true, \"maxLength\": 140, \"sensitive\": true },\n    { \"name\": \"debtorAccountIBAN\",   \"type\": \"ACCOUNT_NUMBER\", \"path\": \"/Document/CstmrCdtTrfInitn/PmtInf/DbtrAcct/Id/IBAN\",                              \"required\": true, \"sensitive\": true },\n    { \"name\": \"creditorName\",        \"type\": \"STRING\",   \"path\": \"/Document/CstmrCdtTrfInitn/PmtInf/CdtTrfTxInf/Cdtr/Nm\",                                \"required\": true, \"maxLength\": 140, \"sensitive\": true },\n    { \"name\": \"instructedAmount\",    \"type\": \"AMOUNT\",   \"path\": \"/Document/CstmrCdtTrfInitn/PmtInf/CdtTrfTxInf/Amt/InstdAmt\",                           \"required\": true, \"scale\": 2 },\n    { \"name\": \"currencyCode\",        \"type\": \"STRING\",   \"path\": \"/Document/CstmrCdtTrfInitn/PmtInf/CdtTrfTxInf/Amt/InstdAmt\", \"xmlAttribute\": \"Ccy\", \"required\": true, \"validationRegex\": \"^[A-Z]{3}$\" },\n    { \"name\": \"remittanceInfo\",      \"type\": \"STRING\",   \"path\": \"/Document/CstmrCdtTrfInitn/PmtInf/CdtTrfTxInf/RmtInf/Ustrd\",                          \"required\": false, \"nullable\": true, \"maxLength\": 140 }\n  ],\n  \"validationRules\": [\n    { \"ruleId\": \"control-sum-positive\",     \"field\": \"controlSum\",       \"ruleType\": \"MIN_VALUE\", \"value\": \"0.01\",          \"message\": \"Control sum must be positive\",     \"severity\": \"ERROR\" },\n    { \"ruleId\": \"instructed-amount-positive\",\"field\": \"instructedAmount\", \"ruleType\": \"MIN_VALUE\", \"value\": \"0.01\",          \"message\": \"Instructed amount must be positive\",\"severity\": \"ERROR\" },\n    { \"ruleId\": \"currency-format\",          \"field\": \"currencyCode\",     \"ruleType\": \"REGEX\",     \"value\": \"^[A-Z]{3}$\",  \"message\": \"Currency must be 3-letter ISO 4217\", \"severity\": \"ERROR\" },\n    { \"ruleId\": \"debtor-name-required\",     \"field\": \"debtorName\",       \"ruleType\": \"NOT_EMPTY\",  \"message\": \"Debtor name is required\",            \"severity\": \"FATAL\" }\n  ],\n  \"correctionRules\": [\n    { \"ruleId\": \"trim-remittance\",    \"field\": \"remittanceInfo\",        \"correctionType\": \"TRIM\",               \"applyOrder\": 1 },\n    { \"ruleId\": \"uppercase-currency\", \"field\": \"currencyCode\",          \"correctionType\": \"UPPERCASE\",          \"applyOrder\": 2 },\n    { \"ruleId\": \"coerce-exec-date\",   \"field\": \"requestedExecutionDate\",\"correctionType\": \"DATE_FORMAT_COERCE\", \"applyOrder\": 3 }\n  ],\n  \"metadata\": { \"standard\": \"ISO-20022\", \"messageType\": \"pain.001\", \"team\": \"swift-payments\" }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/specs", "host": ["{{baseUrl}}"], "path": ["api", "v1", "specs"] }
