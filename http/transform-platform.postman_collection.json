    {
      "name": "05 · Transform",
      "description": "File transformation endpoints. Requires a valid spec ID in the environment.",
      "item": [
        {
          "name": "File to events — CSV (inline data)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has correlationId', () => pm.expect(pm.response.json().correlationId).to.exist);",
                  "const id = pm.response.json().correlationId;",
                  "if (id) { pm.collectionVariables.set('correlationId', id); pm.environment.set('correlationId', id); }",
                  "console.log('Job started:', id, '| total:', pm.response.json().totalRecords);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "specId",             "value": "{{csvSpecId}}", "type": "text",        "description": "ID from 02 · Spec — CSV → Create" },
                { "key": "kafkaTopic",         "value": "{{kafkaTopic}}", "type": "text" },
                { "key": "skipInvalidRecords", "value": "false",          "type": "text" },
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Select a pipe-delimited CSV file. Sample header: TRANSACTION_ID|ACCOUNT_NO|ROUTING_NO|AMOUNT|TXN_DATE|TXN_TYPE|DESCRIPTION|STATUS"
                }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/v1/transform/file-to-events", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transform", "file-to-events"] }
          }
        },
        {
          "name": "File to events — skip invalid records",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "specId",             "value": "{{csvSpecId}}", "type": "text" },
                { "key": "kafkaTopic",         "value": "{{kafkaTopic}}", "type": "text" },
                { "key": "skipInvalidRecords", "value": "true",           "type": "text" },
                { "key": "file",               "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/v1/transform/file-to-events", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transform", "file-to-events"] }
          }
        },
        {
          "name": "File to events — fixed-width NACHA",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "specId",             "value": "{{fixedWidthSpecId}}", "type": "text" },
                { "key": "kafkaTopic",         "value": "transform.ach.records.local", "type": "text" },
                { "key": "skipInvalidRecords", "value": "false", "type": "text" },
                { "key": "file",               "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/v1/transform/file-to-events", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transform", "file-to-events"] }
          }
        },
        {
          "name": "Schedule — run immediately (LOCAL_PATH)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const id = pm.response.json().correlationId;",
                  "if (id) { pm.collectionVariables.set('correlationId', id); pm.environment.set('correlationId', id); }",
                  "console.log('Scheduled job:', id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specId\": \"{{csvSpecId}}\",\n  \"sourceType\": \"LOCAL_PATH\",\n  \"sourceFilePath\": \"/tmp/transform-platform/transactions.csv\",\n  \"destinationType\": \"KAFKA_TOPIC\",\n  \"kafkaTopic\": \"{{kafkaTopic}}\",\n  \"skipInvalidRecords\": false,\n  \"delayMs\": 0,\n  \"runOnce\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/transform/schedule", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transform", "schedule"] }
          }
        },
        {
          "name": "Schedule — delayed 30 seconds",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specId\": \"{{csvSpecId}}\",\n  \"sourceType\": \"LOCAL_PATH\",\n  \"sourceFilePath\": \"/tmp/transform-platform/transactions.csv\",\n  \"destinationType\": \"KAFKA_TOPIC\",\n  \"kafkaTopic\": \"{{kafkaTopic}}\",\n  \"skipInvalidRecords\": false,\n  \"delayMs\": 30000,\n  \"runOnce\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/transform/schedule", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transform", "schedule"] }
          }
        },
        {
          "name": "Schedule — daily cron (02:00)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specId\": \"{{csvSpecId}}\",\n  \"sourceType\": \"LOCAL_PATH\",\n  \"sourceFilePath\": \"/tmp/transform-platform/daily-transactions.csv\",\n  \"destinationType\": \"KAFKA_TOPIC\",\n  \"kafkaTopic\": \"{{kafkaTopic}}\",\n  \"skipInvalidRecords\": false,\n  \"delayMs\": 0,\n  \"cronExpression\": \"0 2 * * *\",\n  \"runOnce\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/transform/schedule", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transform", "schedule"] }
          }
        },
        {
          "name": "Get status by correlationId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has status field', () => pm.expect(pm.response.json().status).to.exist);",
                  "const r = pm.response.json();",
                  "console.log('Status:', r.status, '| total:', r.totalRecords, '| ok:', r.successfulRecords, '| failed:', r.failedRecords);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/transform/status/{{correlationId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transform", "status", "{{correlationId}}"] }
          }
        },
        {
          "name": "ERROR — unknown correlationId (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status is 404', () => pm.response.to.have.status(404));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/transform/status/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transform", "status", "00000000-0000-0000-0000-000000000000"] }
          }
        }
      ]
